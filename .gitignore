# ── Downloads & base de données ──────────────────────────────────────────────
downloads/
*.db
*.db-shm
*.db-wal

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/

# ── Variables d'environnement ─────────────────────────────────────────────────
.env
!.env.example

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/

# ── Assets binaires public (copiés depuis node_modules ou téléchargés) ────────
